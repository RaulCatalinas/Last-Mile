# ----------------------
# Unity .gitignore completo para Desktop (Windows, macOS, Linux)
# ----------------------

# Unity cache / temp
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
[Rr]ecordings/
*.log

# User-specific settings
/[Uu]ser[Ss]ettings/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
.vs/
.vscode/
*.DotSettings.user

# Unity generated crash / system files
sysinfo.txt
mono_crash.*

# Asset store tools (optional)
/[Aa]ssets/AssetStoreTools*

# Blender intermediate files
*.blend1
*.blend1.meta

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app
*.exe
*.x86
*.x86_64
*.dll
*.so
*.dylib

# Addressables
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated test scenes
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# macOS system files
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
*.swp
*~.nib

# Linux system files
*~
.nfs*

# Windows system files
Thumbs.db
ehthumbs.db
Desktop.ini

# Temporary or local files
*.tmp
*.bak
*.backup
*.orig
*.log
